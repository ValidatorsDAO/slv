[Unit]
Description=Pythnet RPC validator (no-voting)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=solv
Group=solv
WorkingDirectory=/home/solv
ExecStart=/home/solv/start-pythnet.sh
Restart=always
RestartSec=5
LimitNOFILE=1048576
TimeoutStopSec=120

[Install]
WantedBy=multi-user.target
