{
  "name": "@slv/cli",
  "version": "2026.5.21.1448",
  "exports": "./dist/exe",
  "publish": {
    "include": [
      "src"
    ],
    "exclude": [
      "src/tests"
    ]
  },
  "tasks": {
    "dev": "deno run -A --watch src/index.ts",
    "build": "deno compile --unstable --allow-all --output dist/exe src/index.ts",
    "start": "deno run -A src/index.ts",
    "test": "deno test -A test/"
  },
  "imports": {
    "@/": "./src/",
    "@/lib": "./lib/",
    "@cmn/": "../cmn/",
    "/": "./",
    "@std/assert": "jsr:@std/assert@1",
    "openai": "https://deno.land/x/openai@v4.69.0/mod.ts",
    "@mariozechner/pi-tui": "npm:@mariozechner/pi-tui@0.61.1",
    "chalk": "npm:chalk@5.4.1"
  },
  "fmt": {
    "semiColons": false,
    "singleQuote": true
  }
}