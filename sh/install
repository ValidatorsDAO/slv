#!/bin/bash

set -e

VERSION="2026.4.21.1752"
BASE_URL="https://storage.slv.dev/slv"
GRPC_TEST_URL_LINUX="https://storage.elsoul.nl/grpc_test"
GRPC_TEST_URL_MAC="https://storage.elsoul.nl/grpc_test_mac"
GEYSERBENCH_URL_LINUX="https://storage.elsoul.nl/geyserbench"
GEYSERBENCH_URL_MAC="https://storage.elsoul.nl/geyserbench_mac"
SHREDS_TEST_URL_LINUX="https://storage.elsoul.nl/bin/latest/deshred"
SHREDS_TEST_URL_MAC="https://storage.elsoul.nl/bin/latest/deshred_mac"

# Detect the platform (Linux/macOS/Windows) and architecture based on 'uname'
detect_platform() {
  uname_out="$(uname -s)"
  arch_out="$(uname -m)"

  case "${arch_out}" in
    x86_64|amd64)   arch="x86_64";;
    arm64|aarch64)  arch="aarch64";;
    *)              echo "Unsupported architecture: ${arch_out}" && exit 1;;
  esac

  case "${uname_out}" in
    Linux*)     platform="${arch}-unknown-linux-gnu"; osfamily="linux";;
    Darwin*)    platform="${arch}-apple-darwin"; osfamily="darwin";;
    CYGWIN*|MINGW*|MSYS*|Windows*) platform="x86_64-pc-windows-msvc"; osfamily="windows";;
    *)          echo "Unsupported platform: ${uname_out}" && exit 1;;
  esac
}

# Install the 'slv' tool
install_slv() {
  # Build the download URLs
  DOWNLOAD_URL="${BASE_URL}/${VERSION}/${platform}-exe.tar.gz?cachebuster=$(date +%s)"
  TEMPLATE_URL="${BASE_URL}/template/${VERSION}/template.tar.gz?cachebuster=$(date +%s)"

  # Prepare directories
  mkdir -p "$HOME/.slv"
  mkdir -p "$HOME/.slv/keys"

  echo "Downloading slv from $DOWNLOAD_URL..."
  # Use --progress-bar to show download progress
  curl -fSL --progress-bar "$DOWNLOAD_URL" -o "$TEMP_DIR/slv.tar.gz"

  # SHA256 checksum verification
  CHECKSUM_URL="${BASE_URL}/${VERSION}/SHA256SUMS"
  echo "Verifying binary integrity..."
  if ! curl -fsSL "$CHECKSUM_URL" -o "$TEMP_DIR/SHA256SUMS"; then
    echo "❌ ERROR: Failed to download checksums. Aborting."
    exit 1
  fi

  EXPECTED_FILE="${platform}-exe.tar.gz"
  cp "$TEMP_DIR/slv.tar.gz" "$TEMP_DIR/$EXPECTED_FILE"

  if command -v sha256sum &>/dev/null; then
    VERIFY_CMD="sha256sum"
  elif command -v shasum &>/dev/null; then
    VERIFY_CMD="shasum -a 256"
  else
    echo "❌ ERROR: sha256sum/shasum not found. Cannot verify."
    exit 1
  fi

  cd "$TEMP_DIR"
  grep "${platform}-exe.tar.gz" "$TEMP_DIR/SHA256SUMS" > "$TEMP_DIR/SHA256SUMS.check"
  if [ ! -s "$TEMP_DIR/SHA256SUMS.check" ]; then
    echo "❌ FATAL: No checksum entry found for ${platform}-exe.tar.gz"
    exit 1
  fi
  if ! $VERIFY_CMD -c SHA256SUMS.check; then
    echo "❌ FATAL: Checksum verification FAILED!"
    echo "The binary may be compromised. Aborting."
    exit 1
  fi
  echo "✅ Binary integrity verified."

  echo "Downloading templates from $TEMPLATE_URL..."
  curl -fSL --progress-bar "$TEMPLATE_URL" -o "$HOME/.slv/template.tar.gz"

  echo "Extracting slv..."
  tar -xzvf "$TEMP_DIR/slv.tar.gz" -C "$TEMP_DIR" --strip-components=1

  echo "Extracting templates..."
  tar -xzvf "$HOME/.slv/template.tar.gz" -C "$HOME/.slv" --strip-components=1
  mkdir -p "$HOME/.slv/template"
  echo "Copying templates to $HOME/.slv/template"

  # Determine the correct executable filename for the current platform
  if [ "$platform" = "x86_64-pc-windows-msvc" ]; then
      SLV_FILE="$TEMP_DIR/slv-x86_64-pc-windows-msvc.exe"
  else
      SLV_FILE="$TEMP_DIR/slv-${platform}-exe"
  fi

  # Check if the extracted file exists
  if [ ! -f "$SLV_FILE" ]; then
    echo "Error: Extracted file not found."
    exit 1
  fi

  echo "Installing slv..."

  # Create the install directory if it doesn't exist
  if [ ! -d "$INSTALL_DIR" ]; then
    echo "$INSTALL_DIR does not exist. Creating it..."
    sudo mkdir -p "$INSTALL_DIR"
  fi

  # Move the executable and make it executable
  if [ "$platform" = "x86_64-pc-windows-msvc" ]; then
    sudo mv "$SLV_FILE" "$INSTALL_DIR/slv.exe"
  else
    sudo mv "$SLV_FILE" "$INSTALL_DIR/slv"
    sudo chmod +x "$INSTALL_DIR/slv"
  fi

  echo "slv has been installed successfully!"
}

# Install the gRPC test binary
# Download a binary only if the remote version is newer than the local copy.
# Uses curl -z (If-Modified-Since) so the server returns 304 when unchanged.
download_if_changed() {
  local url="$1"
  local dest="$2"
  local name
  name="$(basename "$dest")"

  mkdir -p "$(dirname "$dest")"

  if [ -f "$dest" ]; then
    echo "Checking for $name updates..."
    # -z sends If-Modified-Since based on the local file timestamp.
    # curl exits 0 with HTTP 304 (no body written) when unchanged.
    http_code=$(curl -fSL -z "$dest" -o "$dest.tmp" -w '%{http_code}' "$url" 2>/dev/null || true)
    if [ "$http_code" = "304" ] || [ ! -s "$dest.tmp" ]; then
      rm -f "$dest.tmp"
      echo "$name is already up to date."
      return
    fi
    mv -f "$dest.tmp" "$dest"
    chmod +x "$dest"
    echo "$name updated."
  else
    echo "Downloading $name for $osfamily..."
    curl -fSL --progress-bar "$url" -o "$dest"
    chmod +x "$dest"
    echo "$name installed in $dest"
  fi
}

install_grpc_test() {
  mkdir -p "$HOME/.slv/bin"

  if [ "$osfamily" = "darwin" ]; then
    download_if_changed "$GRPC_TEST_URL_MAC" "$HOME/.slv/bin/grpc_test"
  elif [ "$osfamily" = "linux" ]; then
    download_if_changed "$GRPC_TEST_URL_LINUX" "$HOME/.slv/bin/grpc_test"
  else
    echo "Warning: gRPC test binary is not available for $osfamily."
    return
  fi
}

# Install the geyserbench binary
install_geyserbench() {
  mkdir -p "$HOME/.slv/bin"

  if [ "$osfamily" = "darwin" ]; then
    download_if_changed "$GEYSERBENCH_URL_MAC" "$HOME/.slv/bin/geyserbench"
  elif [ "$osfamily" = "linux" ]; then
    download_if_changed "$GEYSERBENCH_URL_LINUX" "$HOME/.slv/bin/geyserbench"
  else
    echo "Warning: geyserbench binary is not available for $osfamily."
    return
  fi
}

# Install the shreds test binary
install_shreds_test() {
  mkdir -p "$HOME/.slv/bin"

  if [ "$osfamily" = "darwin" ]; then
    download_if_changed "$SHREDS_TEST_URL_MAC" "$HOME/.slv/bin/shreds_test"
  elif [ "$osfamily" = "linux" ]; then
    download_if_changed "$SHREDS_TEST_URL_LINUX" "$HOME/.slv/bin/shreds_test"
  else
    echo "Warning: Shreds test binary is not available for $osfamily."
    return
  fi
}

install_skills() {
  echo "Downloading AI agent skills..."
  SKILLS_DIR="$HOME/.slv/skills"
  mkdir -p "$SKILLS_DIR"

  SKILLS_REPO_URL="https://raw.githubusercontent.com/ValidatorsDAO/slv/main/dist/oss-skills"

  for SKILL in slv-validator slv-rpc slv-grpc-geyser slv-benchmark slv-app slv-server-procurement slv-backup; do
    echo "Downloading $SKILL..."
    SKILL_DIR="$SKILLS_DIR/$SKILL"
    mkdir -p "$SKILL_DIR"
    # Download key files
    for FILE in AGENT.md SKILL.md README.md skill.json; do
      curl -fsSL "$SKILLS_REPO_URL/$SKILL/$FILE" -o "$SKILL_DIR/$FILE" 2>/dev/null || true
    done
    # Download scripts
    mkdir -p "$SKILL_DIR/scripts"
    curl -fsSL "$SKILLS_REPO_URL/$SKILL/scripts/setup.sh" -o "$SKILL_DIR/scripts/setup.sh" 2>/dev/null || true
  done

  echo "AI agent skills installed in $SKILLS_DIR"
}

# Install system prerequisites (Linux only)
install_prerequisites() {
  if [ "$osfamily" != "linux" ]; then
    return
  fi

  echo "Checking system prerequisites..."
  local need_apt_update=false
  local pkgs_to_install=""

  # curl (should exist if we got here, but just in case)
  if ! command -v curl &>/dev/null; then
    pkgs_to_install="$pkgs_to_install curl"
  fi

  # python3
  if ! command -v python3 &>/dev/null; then
    pkgs_to_install="$pkgs_to_install python3"
  fi

  # pip3 (needed for ansible-core)
  if ! command -v pip3 &>/dev/null; then
    pkgs_to_install="$pkgs_to_install python3-pip"
  fi

  # gcc / build essentials (sometimes needed for pip packages)
  if ! command -v gcc &>/dev/null; then
    pkgs_to_install="$pkgs_to_install build-essential"
  fi

  if [ -n "$pkgs_to_install" ]; then
    echo "Installing system packages:$pkgs_to_install"
    if command -v apt-get &>/dev/null; then
      sudo apt-get update -qq
      sudo apt-get install -y $pkgs_to_install
    elif command -v dnf &>/dev/null; then
      sudo dnf install -y $pkgs_to_install
    elif command -v yum &>/dev/null; then
      sudo yum install -y $pkgs_to_install
    else
      echo "⚠️  Could not auto-install: $pkgs_to_install"
      echo "   Please install them manually before running 'slv c'."
    fi
  else
    echo "✅ System prerequisites OK"
  fi

  # Install ansible-core if not present
  if ! command -v ansible-playbook &>/dev/null; then
    echo "Installing ansible-core..."
    local installed=false

    # Method 1: Try apt install (works on Ubuntu 24.04+ without PEP 668 issues)
    if command -v apt-get &>/dev/null; then
      if sudo apt-get install -y ansible-core 2>/dev/null; then
        installed=true
      fi
    fi

    # Method 2: Try dnf
    if [ "$installed" = false ] && command -v dnf &>/dev/null; then
      if sudo dnf install -y ansible-core 2>/dev/null; then
        installed=true
      fi
    fi

    # Method 3: pip3 with --break-system-packages (fallback for older distros)
    if [ "$installed" = false ] && command -v pip3 &>/dev/null; then
      if [ "$(id -u)" -eq 0 ]; then
        pip3 install --break-system-packages ansible-core 2>/dev/null || pip3 install ansible-core 2>/dev/null || true
      else
        pip3 install --user --break-system-packages ansible-core 2>/dev/null || pip3 install --user ansible-core 2>/dev/null || true
        export PATH="$HOME/.local/bin:$PATH"
      fi
      command -v ansible-playbook &>/dev/null && installed=true
    fi

    if [ "$installed" = true ] || command -v ansible-playbook &>/dev/null; then
      echo "✅ ansible-core installed"
    else
      echo "⚠️  Could not auto-install ansible-core. Install manually: sudo apt install ansible-core"
    fi
  else
    echo "✅ ansible-core already installed"
  fi
}

# Main installation process
main() {
  echo "Detecting platform..."
  detect_platform
  echo "Platform detected: $platform ($arch)"

  # Set install directory based on platform
  INSTALL_DIR="/usr/local/bin"
  if [ "$platform" = "x86_64-pc-windows-msvc" ]; then
    INSTALL_DIR="$HOME/.local/bin"
    mkdir -p "$INSTALL_DIR"
  fi

  # Install system prerequisites before anything else
  install_prerequisites

  # Create temporary directory
  TEMP_DIR=$(mktemp -d)
  echo "Temporary directory: $TEMP_DIR"

  # Install slv
  install_slv

  # Install gRPC test binary and wrapper
  install_grpc_test

  # Install geyserbench binary
  install_geyserbench

  # Install shreds test binary
  install_shreds_test

  # Install AI agent skills
  install_skills

  # Clean up
  echo "✨ Cleaning up..."
  cd "$HOME" || cd /
  rm -rf "$TEMP_DIR"
  rm -f "$HOME/.slv/template.tar.gz"

  echo "All components installed successfully!"
  echo "Ensure $INSTALL_DIR is in your PATH."
  if [ "$platform" = "x86_64-pc-windows-msvc" ]; then
    echo "Windows users, add $INSTALL_DIR to your PATH manually."
  fi

  slv upgrade:settings || echo "⚠️ upgrade:settings encountered an error (non-fatal, templates may need re-download via 'slv upgrade')"

  # Optional: Test the installed 'slv'
  echo "Testing slv installation... 🔨"
  slv -P || true

  echo "Try 'slv backup' to protect your node environment:"
  echo "  slv backup create   — Create a backup of the current node"
  echo "  slv backup list     — List available backups and snapshots"
}

# Run the main function
main
